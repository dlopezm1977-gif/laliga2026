# Copia este fichero como .env y rellena los valores
# Obtén estos valores en Firebase Console > Configuración del proyecto

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Token de football-data.org (plan gratuito)
# Regístrate en https://www.football-data.org/client/register
VITE_FD_TOKEN=
